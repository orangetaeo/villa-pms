// Villa PMS — Prisma Schema v1.2
// 금액 규칙: VND = BigInt(동), KRW = Int(원). 숙박일 = @db.Date
// v1.1: AuditLog·AppSetting 추가 (ADR-0002)
// v1.2: 채널별 결제 통화(saleCurrency·salePriceVnd·환율 스냅샷), VillaAmenity 비품, Zalo 양방향 채팅 (ADR-0003)
// v1.2a: ZaloCounterpartyType 분류 5종 확장 — TRAVEL_AGENCY·LAND_AGENCY 추가 (ADR-0009 개정 2026-06-16, additive enum)
// v1.2b: ZaloMessage 답글(인용)·리액션 — cliMsgId·quotedMsgId·quotedText·quotedSender·reactions 추가 (ADR-0009 개정3 2026-06-16, additive)
// v1.2c: ZaloCounterpartyType IGNORED 추가 — 개인/기타(업무 상대 아님) 종착 분류, 분류 배너 영구 미노출 (2026-06-22, additive enum)
// v1.3: 빌라 판매용 정보 확장 — Villa 스칼라 13 + enum BedType·FeatureCategory + 모델 VillaBedroom·VillaFeature (ADR-0011, additive only)
// v1.3a: Villa.availabilityCheckedAt 추가 — 운영자 공실 보드 "마지막 확인일" (T-admin-availability-board, additive only)
// v1.3b: Zalo 그룹 채팅 — enum ZaloThreadType + ZaloConversation.threadType·groupMembers + ZaloMessage.senderUid (ADR-0010 S4, additive only)
// v1.3c: 운영자 권한 3단계 — enum Role에 OWNER·MANAGER·STAFF 추가 (ADR-0013 S-RBAC-1, additive only — ADMIN 유지·transition 중 OWNER 동일취급, 치환·제거는 S-RBAC-2)
// v1.4: VillaBedroom.bathroomCount 추가 — 침실별 전용욕실 개수, Villa.bathrooms 자동 합산 (Batch A 3, additive only)
// v1.5: VillaRatePeriod 추가 — 기간별 요금(기본요금+웃돈기간 N), dual-read 공존 (ADR-0014, additive only — VillaRate·VillaSeasonPeriod 무변경)
// v1.6: 구 요율 테이블 제거 — VillaRate·VillaSeasonPeriod DROP, VillaRatePeriod 단일 소스 (ADR-0015 Phase C, 전 빌라 전환·백업 완료 후)
// v1.4: VillaBedroom.bathroomCount 추가 — 침실별 전용욕실 개수, Villa.bathrooms 자동 합산 (Batch A 3, additive only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== 사용자 =====================

enum Role {
  ADMIN // 운영자(테오) — 구 단일 운영자. transition 중 OWNER 동일취급, S-RBAC-2서 OWNER로 치환·제거
  OWNER // 최상위 운영자 — 모든 것 + 시스템 통제 (ADR-0013)
  MANAGER // 관리자 — 운영 총괄 + 재무 전체 가시성, 시스템 통제 없음 (ADR-0013)
  STAFF // 직원 — 운영 실무, 돈(마진·KRW·정산)만 차단 (ADR-0013)
  SUPPLIER // 중계인·부동산·분양자
  CLEANER // 청소 담당
  VENDOR // 원천 공급자 — 부가서비스(과일·BBQ·렌트 등) 외부 거래처, /vendor 대시보드 (ADR-0023)
  PARTNER // 여행사·랜드사 — 자기 고객 예약현황·미수만 조회, /partner 포털 (ADR-0028)
}

model User {
  id           String   @id @default(cuid())
  role         Role
  name         String
  phone        String?  @unique
  email        String?  @unique
  passwordHash String?
  zaloUserId   String?  @unique // Zalo OA 알림 수신용(자동 연결 시 캡처되는 내부 id, @unique)
  // 공급자가 가입 시 직접 입력한 Zalo 연락처(전화·display id) — 운영자 참고용.
  // zaloUserId(자동 매칭용 내부 id)와 별개이며 @unique 아님(중복 허용). additive.
  zaloContact  String?
  // 정산받을 계좌(은행·계좌·예금주) — Json. ★운영자(canViewFinance) 전용, 공급자 화면 미노출.
  // SUPPLIER 자가가입 시 선택 입력. additive.
  bankInfo     Json?
  locale       String   @default("vi") // vi | ko
  isActive     Boolean  @default(true)
  // 임시 비밀번호(OWNER 초기화·계정생성) 발급 시 true → 본인이 변경 전까지 다른 화면 차단
  mustChangePassword Boolean @default(false)
  // 마지막 비밀번호 변경 시각 (보안 P0-5② 서버측 세션 무효화) — 이 시각 이전 발급 JWT는 무효.
  // null=기능 도입 후 한 번도 안 바꿈(=epoch 0 취급). additive, 라이브는 raw SQL ALTER.
  passwordChangedAt DateTime?
  createdAt    DateTime @default(now())
  // 소프트 삭제 — null=정상, 값=삭제됨(목록·로그인 제외, 데이터·빌라는 보존). 복구는 DB에서 deletedAt=null
  deletedAt    DateTime?

  villas        Villa[]        @relation("SupplierVillas")
  assignedVillas Villa[]       @relation("VillaCleaner") // 청소 담당으로 지정된 빌라 (CLEANER)
  cleaningTasks CleaningTask[] @relation("AssignedCleaner")
  settlements   Settlement[]
  notifications Notification[]
  inAppNotifications InAppNotification[] // 인앱 알림(벨·읽음상태) — VENDOR 포털, additive
  resolvedChangeRequests BookingChangeRequest[] @relation("ChangeRequestResolver") // 파트너 요청 처리자(운영자) — additive
  auditLogs     AuditLog[]
  vendorAccount ServiceVendor? @relation("VendorAccount") // 원천 공급자 로그인 계정 (Role=VENDOR, ADR-0023)
  partnerAccount Partner?      @relation("PartnerAccount") // 파트너(여행사·랜드사) 로그인 계정 (Role=PARTNER, ADR-0028)
  passwordResetTokens PasswordResetToken[] // 비밀번호 자가재설정(Zalo 6자리 코드) — additive
  authenticators Authenticator[] // WebAuthn/패스키(지문·얼굴) 로그인 자격증명 — additive

  // Zalo 멀티 관리자 (ADR-0007) — 역관계 1:N화
  zaloAccounts          ZaloAccount[]      @relation("AdminZaloAccounts") // 관리자가 소유한 봇 계정 (개인 + (테오만)시스템)
  ownedConversations    ZaloConversation[] @relation("AdminConversations") // 관리자가 받은 대화 (개인 스코프 기준)
  supplierConversations ZaloConversation[] @relation("SupplierConversations") // 공급자로서 매칭된 대화 (전역 zaloUserId 조인)
}

// 비밀번호 자가재설정 토큰 (Zalo 6자리 코드 방식, ADR — password-self-reset).
// codeHash만 저장(평문 코드 미저장). expiresAt=now+10분. attempts>=5면 폐기. usedAt=사용 시각.
// additive — 라이브 Neon에는 raw SQL CREATE TABLE로 적용(prisma db push 금지, 드리프트 방지).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String // bcrypt 해시 — 평문 6자리 코드는 절대 저장하지 않는다
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// WebAuthn/패스키 자격증명 (지문·얼굴·Windows Hello 로그인, ADR-0030).
// 공개키만 저장(개인키는 사용자 기기 보안영역에만 존재 — 서버는 비밀번호처럼 훔칠 것이 없다).
// counter=재생공격 방지 카운터. credentialId=base64url. publicKey=COSE 공개키(base64url 문자열로 보관).
// additive — 라이브 Neon에는 raw SQL CREATE TABLE로 적용(prisma db push 금지, 드리프트 방지).
model Authenticator {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique // base64url — 자격증명 식별자
  publicKey    String // base64url(COSE 공개키 바이트)
  counter      BigInt    @default(0) // 서명 카운터(재생공격 방지)
  transports   String? // csv: "internal,hybrid,usb" 등(선택)
  deviceName   String? // 사용자 식별용 라벨(예: "iPhone", "내 노트북")
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

// ===================== 빌라 =====================

enum VillaStatus {
  DRAFT // 등록 중
  PENDING_REVIEW // 운영자 승인 대기
  REJECTED // 운영자 반려 (rejectionReason) — 공급자 수정·재제출 시 PENDING_REVIEW (T1.2b)
  ACTIVE // 운영 중
  INACTIVE // 중단
}

// 빌라 공급 출처 (T-availability-direct-booking-popover).
// SUPPLIER = 외부 공급자(중계인·부동산·분양자)가 등록 — 재고/예약 비공개 대상.
// DIRECT   = 테오팀이 직접 수집·공급 — 외부 공급자가 없어 공실 보드에서 우리 예약을 노출해도 누수 없음.
enum VillaSource {
  SUPPLIER
  DIRECT
}

enum PhotoSpace {
  EXTERIOR // 외관
  LIVING // 거실
  KITCHEN // 주방
  BEDROOM // 침실 (spaceLabel로 1층/2층-1 구분)
  BATHROOM // 화장실
  BALCONY // 베란다
  POOL // 수영장
  ETC
}

model Villa {
  id                 String  @id @default(cuid())
  supplierId         String
  supplier           User    @relation("SupplierVillas", fields: [supplierId], references: [id])
  // 빌라별 청소 담당자(회사 CLEANER 직원). 미지정이면 공급자(supplier)가 청소 담당 — 폴백.
  // additive(T-villa-cleaner-assign). 지역이 넓어 한 명이 전 빌라를 못 하므로 빌라 단위 배정.
  cleanerId          String?
  cleaner            User?   @relation("VillaCleaner", fields: [cleanerId], references: [id])
  name               String // 예: 쏘나씨 V12 (운영자 기준 한국어명)
  nameVi             String? // 베트남어/라틴 병기명 (예: Sonasea V12) — Gemini 제안+ADMIN 확정, ADR-0020. 비운영자 화면에 병기
  complex            String? // 단지명: 쏘나씨, 썬셋 사나토
  address            String?
  bedrooms           Int
  bathrooms          Int
  maxGuests          Int
  hasPool            Boolean @default(false)
  breakfastAvailable Boolean @default(false) // 조식 가능 여부
  monthlyRentVnd     BigInt? // 참고용 월 임대 시세
  description        String?
  descriptionVi      String?

  // ── 판매용 정보 확장 (v1.3 / ADR-0011) — additive only, 기존 컬럼 변경 없음 ──
  // ③ 위치·접근성 — 모두 정수 단위(부동소수점 금지). 미입력 허용(nullable)
  googleMapUrl      String? // 구글맵 공유 링크 (place URL) — ADMIN 입력
  beachDistanceM    Int? // 해변까지 거리(미터, 정수). ㎞ 환산은 표시단에서
  areaSqm           Int? // 전용면적(㎡, 정수). 소수점 면적은 반올림 입력
  floors            Int? // 층수(정수). 단층=1, 복층=2
  // ④ 이용규칙
  checkInTime       Int     @default(840) // 분 단위(0~1439). 840 = 14:00
  checkOutTime      Int     @default(660) // 분 단위. 660 = 11:00
  smokingAllowed    Boolean @default(false)
  petsAllowed       Boolean @default(false)
  partyAllowed      Boolean @default(false)
  parkingSlots      Int     @default(0) // 주차 가능 대수
  baseDepositVnd    BigInt? // 기준 보증금(VND BigInt, 동 단위). Booking.depositAmount와 별개(빌라 기본값)
  wifiSsid          String? // 와이파이 이름 — 공개 노출 가능
  wifiPassword      String? // ⚠ 와이파이 비번 — /p 공개페이지 절대 노출 금지(체크인 화면 전용). select 화이트리스트 §4.3
  // ── 청소직원용 운영 정보 (additive, T-cleaner-features C·D) — 배정된 청소직원·운영자만 노출(게스트 비공개) ──
  accessType        String? // 출입 방식: KEYPAD(번호키)·KEY(열쇠)·OTHER. 빌라마다 다름(번호키 없는 곳도 있음)
  accessInfo        String? // 출입정보(도어코드/키 위치) — 청소직원·운영자 전용. /g·/p 공개경계 절대 노출 금지
  cleaningNotes     String? // 청소 특이사항/지시(에어컨 필터·곰팡이 주의 등) — 빌라 단위 재사용
  // ⑤ 엑스트라베드 — 빌라 단위 토글(침실별 아님)
  extraBedAvailable Boolean @default(false)

  status          VillaStatus @default(DRAFT)
  // 공급 출처 — 기존 빌라는 전부 SUPPLIER(default)로 백필. DIRECT는 ADMIN만 지정(별도 폼).
  // 공실 보드는 DIRECT 빌라에 한해 우리 판매예약을 셀에 표시한다 (재고 비공개 예외 — 누수 대상 없음).
  source          VillaSource @default(SUPPLIER)
  rejectionReason String? // 마지막 반려 사유 (T1.2b) — 재제출 시 null 클리어, 이력은 AuditLog
  isSellable      Boolean     @default(false) // 청소 검수 게이트 통과 여부
  qualityScore    Int         @default(100) // Phase 2: 누적 품질점수
  icalImportUrls  String[] // 외부 채널 iCal 수신 URL (Airbnb 등)
  // 운영자가 이 빌라의 공실을 공급자에게 마지막으로 확인한 시각. null = 아직 확인 안 함("확인필요"로 표시)
  availabilityCheckedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  photos         VillaPhoto[]
  blocks         CalendarBlock[]
  bookings       Booking[]
  proposalItems  ProposalItem[]
  cleaningTasks  CleaningTask[]
  amenities      VillaAmenity[] // 비품 (ADR-0003)
  ratePeriods    VillaRatePeriod[] // 기간별 요금 단일 소스 (ADR-0014/0015) — 구 VillaRate·VillaSeasonPeriod 제거됨
  bedroomDetails VillaBedroom[] // ② 침실별 잠자리 구성 (ADR-0011) — 기존 Int 컬럼 bedrooms와 별개
  features       VillaFeature[] // ⑤ 셀링포인트 태그 (ADR-0011, 사전 패턴)
  minibarStocks  VillaMinibarStock[] // #2c: 빌라별 미니바 비치수량 오버라이드 (가격은 회사표준 유지)

  @@index([supplierId])
  @@index([status, isSellable])
}

model VillaPhoto {
  id         String     @id @default(cuid())
  villaId    String
  villa      Villa      @relation(fields: [villaId], references: [id], onDelete: Cascade)
  space      PhotoSpace
  spaceLabel String? // "2층 침실 1" 등 자유 라벨
  url        String
  isBaseline Boolean    @default(true) // 기준 사진 (체크아웃 비교용)
  sortOrder  Int        @default(0)
  uploadedBy String?
  createdAt  DateTime   @default(now())

  @@index([villaId, space])
}

// ===================== 판매용 정보 확장 (v1.3 — ADR-0011) =====================

// 침대 종류 — 코드 사전(lib/bedding.ts)과 정합. enum으로 고정해 임의값 차단.
// 테오 확정(2026-06-22): 6종. TWIN = 싱글 2개 구성 침실 표기용.
enum BedType {
  KING // 킹
  QUEEN // 퀸
  DOUBLE // 더블
  SINGLE // 싱글
  TWIN // 트윈 (싱글 2개)
  BUNK // 2층 침대
}

// 셀링포인트 분류 — 표시 그룹핑·필터용
enum FeatureCategory {
  VIEW // 뷰 (바다/마운틴/시티 — 다중 가능)
  FACILITY // 시설 (BBQ·엘리베이터·발전기·키즈풀 등)
  LOCATION // 입지 (골프장 인근 등)
}

// ② 침실별 잠자리 구성 (ADR-0011). VillaPhoto / VillaAmenity 와 동일한 1:N 자식 패턴.
// 한 침실에 침대가 여러 종류면 행을 여러 개(같은 villaId·roomIndex, bedType만 다름) 둔다.
model VillaBedroom {
  id        String  @id @default(cuid())
  villaId   String
  villa     Villa   @relation(fields: [villaId], references: [id], onDelete: Cascade)
  roomIndex Int // 침실 번호(1-base). VillaPhoto.spaceLabel "침실1"과 의미 정합
  roomLabel String? // 자유 라벨("마스터룸", "2층 침실") — 미입력 시 표시단에서 "침실N"
  bedType   BedType
  bedCount  Int     @default(1) // 이 종류 침대 개수
  capacity  Int? // 이 침실 수용 인원(선택). 같은 roomIndex 행들은 동일값 — BE 검증
  bathroomCount Int @default(0) // 이 침실 전용(ensuite) 욕실 개수. 같은 roomIndex 행들은 동일값 — BE 검증. Villa.bathrooms는 침실 합계로 자동 갱신 (v1.4)

  @@index([villaId, roomIndex])
}

// ⑤ 셀링포인트 태그 (ADR-0011). VillaAmenity 사전 패턴 재사용 — featureKey는 lib/features.ts 사전 키.
// 다중선택 = 체크된 featureKey마다 행 1개. 화이트리스트 검증은 isValidFeature()(lib/features.ts).
model VillaFeature {
  id         String          @id @default(cuid())
  villaId    String
  villa      Villa           @relation(fields: [villaId], references: [id], onDelete: Cascade)
  category   FeatureCategory
  featureKey String // 사전 키 (코드 상수 → i18n: features.items.viewSea 등)

  @@unique([villaId, featureKey]) // 같은 태그 중복 방지
  @@index([villaId, category])
}

// ===================== 비품 (v1.2 — ADR-0003) =====================

enum AmenityCategory {
  KITCHEN // 주방용품
  BATHROOM // 화장실용품
  APPLIANCE // 가전류
  MINIBAR // 미니바 — 물·음료·과자 (수량 의미 있음)
}

// 빌라 비치 품목. Phase 1: 표기·조회만 (F1 마법사 4/5단계 + b10 + b4 읽기 전용 체크리스트)
// Phase 2: 체크아웃 미니바 소모 자동 차감과 연결 (IDEAS.md)
model VillaAmenity {
  id          String          @id @default(cuid())
  villaId     String
  villa       Villa           @relation(fields: [villaId], references: [id], onDelete: Cascade)
  category    AmenityCategory
  itemKey     String // 품목 사전 키 (코드 상수 → i18n: amenity.kettle 등). 직접 입력은 "custom"
  customLabel String? // itemKey="custom"일 때 공급자 입력 라벨 (vi)
  quantity    Int             @default(1) // MINIBAR: 비치 수량, 그 외: 1=있음
  unitPrice   BigInt? // 미니바 고객 청구 단가 — VND 고정(통화 컬럼 없음, 동 단위). 부동소수점 금지 (ADR-0008)
  note        String?
  updatedAt   DateTime        @updatedAt

  @@index([villaId, category])
}

// 미니바 회사표준 1세트 (#2b, ADR-0016). 빌라별이 아니라 전 빌라 공통 — villaId 없음(공급자 쿼리 구조적 도달 불가).
//   unitPriceVnd = 우리 회사 고객 청구 단가(= 판매가). 공급자·공개(/p) 라우트엔 절대 노출 금지(마진 비공개 원칙2).
//   체크아웃은 소모 수량 직접 입력 → 차감액 = 소모 × unitPriceVnd (BigInt, 부동소수점 금지).
model MinibarItem {
  id           String   @id @default(cuid())
  itemKey      String   @unique // 안정 식별 코드(자동생성 mb_*) — 표시명 변경과 무관한 키
  nameKo       String // 한국어 품목명 (운영자 표시)
  nameVi       String? // 베트남어 품목명 (선택)
  unitPriceVnd BigInt // 고객 청구 단가 VND, 동 단위. 우리 판매가 — 공급자 비노출
  // 매입 원가 VND(동) — 추후 "원가 입력 UI" 신설 시 채움(현재 nullable). 미니바 마진=판매−원가 통계용.
  // ★ 공급자·공개 라우트 절대 비노출(마진 비공개 원칙2). 원가 미입력이면 마진 통계는 "원가 미입력"으로 표기.
  costVnd      BigInt?
  stockQty     Int      @default(1) // 기본 비치 수량 — 각 빌라에 기본 비치하는 개수(체크아웃 소모 계산 기준)
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  villaStocks  VillaMinibarStock[] // #2c: 이 품목의 빌라별 비치수량 오버라이드
  checkoutLines CheckoutMinibarLine[] // 체크아웃 판매 라인(통계 소스) — 품목 삭제 시 라인은 SetNull로 보존

  @@index([active, sortOrder])
}

// 빌라별 미니바 비치수량 오버라이드 (#2c) — 냉장고 크기·현재 재고가 빌라마다 달라 stockQty를 빌라별로 조정.
//   ★ 수량(qty)만 빌라별이다. 가격(unitPriceVnd)은 회사표준(MinibarItem) 그대로 — 빌라별로 두지 않는다(원칙2 마진 비공개 유지).
//   오버라이드 행이 없는 (빌라×품목)은 MinibarItem.stockQty를 그대로 사용한다(기본값). 편집은 ADMIN 전용.
model VillaMinibarStock {
  id            String      @id @default(cuid())
  villaId       String
  villa         Villa       @relation(fields: [villaId], references: [id], onDelete: Cascade)
  minibarItemId String
  minibarItem   MinibarItem @relation(fields: [minibarItemId], references: [id], onDelete: Cascade)
  qty           Int // 이 빌라의 실제 비치 수량 (0 이상)
  updatedAt     DateTime    @updatedAt

  @@unique([villaId, minibarItemId])
  @@index([villaId])
}

// 미니바 실재고 이동 원장 (ADR-0019 S1). 현재고는 캐시 컬럼이 아니라 이 원장의 ΣqtyDelta로 산출한다
//   (VillaMinibarStock 행은 표준 추종 시 삭제되는 sparse 구조라 현재고 캐시를 둘 수 없음 — 원장 단일소스).
//   RESTOCK(+입고, unitCostVnd 매입단가→MinibarItem.costVnd 갱신) / CONSUME(−체크아웃 소모) / ADJUST(±수동 보정).
//   현재고(빌라×품목) = ΣqtyDelta, 부족 = 현재고 < 비치목표(par = VillaMinibarStock.qty ?? MinibarItem.stockQty).
//   ★ unitCostVnd(원가)는 운영자(canViewFinance) 전용 — 공급자·공개 라우트 비노출(마진 비공개 원칙2).
enum MinibarMovementType {
  RESTOCK // 입고(매입)
  CONSUME // 소모(체크아웃)
  ADJUST // 수동 보정(분실·실사)
  RECOVER // 전환 회수(−) — 다음 예약 seller=SUPPLIER일 때 빌라 재고 전량 회수 (ADR-0021 D6)
}

model MinibarStockMovement {
  id            String              @id @default(cuid())
  villaId       String
  minibarItemId String
  type          MinibarMovementType
  qtyDelta      Int // +입고 / −소모·차감 (현재고 = ΣqtyDelta)
  unitCostVnd   BigInt? // RESTOCK 매입 단가(VND, 동) — 운영자 전용
  bookingId     String? // CONSUME 출처 예약
  note          String?
  createdBy     String
  createdAt     DateTime            @default(now())

  @@index([villaId, minibarItemId])
  @@index([createdAt])
}

// ===================== 시즌·요율 =====================

enum SeasonType {
  LOW // 비수기
  HIGH // 성수기
  PEAK // 극성수기 (연말·설)
}

model SeasonPeriod {
  id        String     @id @default(cuid())
  season    SeasonType
  startDate DateTime   @db.Date
  endDate   DateTime   @db.Date
  label     String? // "2026 설 연휴"

  @@index([startDate, endDate])
}

enum MarginType {
  PERCENT
  FIXED_VND // v1.2: FIXED_KRW → FIXED_VND. 마진 기준통화를 원가와 동일한 VND로 통일 (ADR-0003)
}

// 기간별 요금 (ADR-0014) — 빌라 요율 단일 소스. 가격 산정 기준통화 = VND.
//   salePriceVnd = 원가 + 마진(자동계산 후 ADMIN 오버라이드), salePriceKrw = salePriceVnd × FX 환산 후 라운딩.
// isBase=true: 비수기 기본요금(날짜 무관·배경), villa당 정확히 1개(앱 트랜잭션 보장).
// isBase=false: 웃돈 기간(startDate·endDate 필수, half-open). 같은 빌라 내 겹침 입력단계 거부.
// 견적(quoteStayForVilla): base + 숙박구간 교차기간으로 박별 합산(ADR-0015에서 구 VillaRate 폴백 제거, 단일 경로).
// 권한: 공급자=supplierCostVnd만, 관리자(canSetPrice)=margin·salePrice (API select/입력 화이트리스트로 분리).
model VillaRatePeriod {
  id              String     @id @default(cuid())
  villaId         String
  villa           Villa      @relation(fields: [villaId], references: [id], onDelete: Cascade)
  season          SeasonType // 분류 라벨(LOW/HIGH/PEAK) — 표시·정렬용, 가격 키 아님
  isBase          Boolean    @default(false) // true=기본요금(날짜 없음·폴백)
  startDate       DateTime?  @db.Date // isBase=false일 때 필수. 포함
  endDate         DateTime?  @db.Date // isBase=false일 때 필수. 제외 — half-open
  label           String? // "2026 설", "여름 성수기 1차"
  supplierCostVnd BigInt // 공급자 입력 — 이 기간 원가/박
  marginType      MarginType @default(PERCENT)
  marginValue     BigInt // 관리자 — PERCENT: %, FIXED_VND: 동
  salePriceVnd    BigInt // 관리자 책정 — Net(도매/여행사·랜드사) 판매가/박 (VND 채널)
  salePriceKrw    Int // 관리자 책정 — Net(도매/여행사·랜드사) 판매가/박 (KRW 채널)
  // ADR-0031 — 소비자 직판가(2단계 가격). Net 대비 추가마진. DIRECT(직접 소비자) 채널 견적에만 사용.
  //   null이면 Net(salePrice*)으로 폴백 → 마크업 미설정 빌라는 기존 동작 유지(무중단).
  //   ⚠ 마진 비공개(원칙2): 공급자·공개(/p·/g) 라우트엔 salePrice*·consumer* 모두 절대 비노출.
  consumerMarginType   MarginType @default(PERCENT) // 소비자 마진 유형 (Net 대비)
  consumerMarginValue  BigInt     @default(0) // 소비자 추가마진 — PERCENT: %, FIXED_VND: 동. 0=Net과 동일
  consumerSalePriceVnd BigInt? // 소비자 직판가/박 (VND). null=salePriceVnd 폴백
  consumerSalePriceKrw Int? // 소비자 직판가/박 (KRW). null=salePriceKrw 폴백
  supplierSalePriceVnd BigInt? // F10 Phase B: 공급자 자기 판매 정가/박 (VND) — 운영자 salePriceVnd·마진과 완전 별개, 공급자 직접 판매 링크용 (ADR-0021)
  updatedAt       DateTime   @updatedAt

  @@index([villaId, startDate, endDate])
  @@index([villaId, isBase])
}

// ===================== 캘린더 =====================

enum BlockSource {
  MANUAL // 공급자/운영자 수동 차단
  ICAL // 외부 채널 동기화
}

// 예약 외 점유 (외부 판매분, 수리 등). 가용성 = NOT(booking) AND NOT(block)
model CalendarBlock {
  id        String      @id @default(cuid())
  villaId   String
  villa     Villa       @relation(fields: [villaId], references: [id], onDelete: Cascade)
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date // exclusive (체크아웃일)
  source    BlockSource @default(MANUAL)
  icalUid   String? // iCal 이벤트 UID (동기화 멱등성)
  note      String?
  createdBy String?
  createdAt DateTime    @default(now())

  @@unique([villaId, icalUid])
  @@index([villaId, startDate, endDate])
}

// ===================== 제안·가예약·예약 =====================

enum ProposalStatus {
  ACTIVE
  USED // 가예약 발생
  EXPIRED
  REVOKED
}

model Proposal {
  id           String         @id @default(cuid())
  token        String         @unique @default(cuid()) // 공개 링크: /p/[token]
  clientName   String // 여행사명 또는 고객명
  channel      BookingChannel
  saleCurrency Currency       @default(KRW) // 채널 기본값: DIRECT→KRW, 랜드사·여행사→VND. 생성 시 ADMIN 오버라이드 가능 (ADR-0003)
  fxVndPerKrw  Decimal?       @db.Decimal(14, 4) // 제안 생성 시점 환율 스냅샷 (1 KRW = x VND) — 참고 환산·마진 리포팅용
  fxVndPerUsd  Decimal?       @db.Decimal(14, 4) // Phase 2 USD: 제안 생성 시점 USD→VND 환율 스냅샷 (1 USD = x VND). additive raw SQL ALTER로 라이브 반영
  expiresAt    DateTime
  status       ProposalStatus @default(ACTIVE)
  note         String?
  seller       BookingSeller  @default(OPERATOR) // F10 Phase B: 제안 링크 판매 주체. SUPPLIER=공급자 직접 판매 링크 (ADR-0021)
  supplierId   String? // F10 Phase B: 공급자 직접 판매 링크 소유자. null=운영자 제안 링크 (ADR-0021)
  partnerId    String? // 여행사·랜드사 파트너 연결(선택). null=일반 소비자(clientName 자유 텍스트). 가예약→예약 전환 시 partner 승계용
  createdAt    DateTime       @default(now())

  partner Partner?       @relation(fields: [partnerId], references: [id])
  items   ProposalItem[]
}

model ProposalItem {
  id               String   @id @default(cuid())
  proposalId       String
  proposal         Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  villaId          String
  villa            Villa    @relation(fields: [villaId], references: [id])
  checkIn          DateTime @db.Date
  checkOut         DateTime @db.Date
  // 금액 — proposal.saleCurrency에 해당하는 통화 컬럼만 채운다 (KRW ⇒ *Krw 필수 / VND ⇒ *Vnd 필수, ADR-0003)
  priceKrwPerNight Int?
  totalKrw         Int?
  priceVndPerNight BigInt?
  totalVnd         BigInt?
  totalUsd         Int? // Phase 2 USD: 총 판매가(USD, 정수 달러). 요율표 미보유 → ADMIN 수동 입력. additive raw SQL ALTER로 라이브 반영
  bookingId        String?  @unique // 가예약 발생 시 연결

  booking Booking? @relation(fields: [bookingId], references: [id])
}

enum BookingStatus {
  HOLD // 가예약 (holdExpiresAt까지)
  CONFIRMED // 입금 확정
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  EXPIRED // 홀드 만료 자동 해제
  NO_SHOW
}

enum BookingChannel {
  TRAVEL_AGENCY // 여행사
  LAND_AGENCY // 랜드사
  DIRECT // 직접 소비자
}

// 누가 이 예약을 판매했는가 (F10 양방향 모델, ADR-0021)
// OPERATOR=우리 재판매(정산 대상) / SUPPLIER=공급자 직접판매(정산 제외, 공급자 100%)
// ※ 단어 DIRECT는 BookingChannel.DIRECT(결제통화)·Villa.source=DIRECT(소싱)와 충돌 → seller로 표현
enum BookingSeller {
  OPERATOR
  SUPPLIER
}

model Booking {
  id                String         @id @default(cuid())
  villaId           String
  villa             Villa          @relation(fields: [villaId], references: [id])
  status            BookingStatus
  channel           BookingChannel
  seller            BookingSeller  @default(OPERATOR) // F10: 판매 주체. SUPPLIER=공급자 직접판매(정산 제외) — ADR-0021
  supplierSalePriceVnd BigInt?     // 공급자가 자기 고객에게 받은 금액(공급자 직접판매 기록용, 우리 회계 무관)
  checkIn           DateTime       @db.Date
  checkOut          DateTime       @db.Date // exclusive
  nights            Int
  guestName         String // 예약 식별명 (가예약 시점) — 여행사 채널은 최종 투숙객과 다를 수 있음
  guestCount        Int
  guestPhone        String?
  guestRoster       String? // 실제 투숙객 명단(예: "김학태 / 이영희") — 입금 확정~체크인 전날 ADMIN 입력, 여권 OCR 전 준비용 (T-guest-roster)
  agencyName        String? // [dual-read 폴백] Partner 승격 전 텍스트. ADR-0022: partnerId 우선, 없으면 이 값
  partnerId         String? // 여행사/랜드사 파트너 (ADR-0022 — B2B 객실료 채권 귀속). null=직접/미지정
  partner           Partner?       @relation(fields: [partnerId], references: [id])
  // ADR-0030 T-E: 분할 숙박 — 연장인데 원 빌라가 불가해 다른 빌라로 이어 묵는 추가 예약이 원(부모)을 가리킴.
  // null=독립 예약. 각 예약은 여전히 단일 빌라. 라이브 반영은 additive raw SQL ALTER(prisma db execute).
  parentBookingId   String?
  parentBooking     Booking?       @relation("BookingExtensions", fields: [parentBookingId], references: [id], onDelete: SetNull)
  extensions        Booking[]      @relation("BookingExtensions")
  changeRequests    BookingChangeRequest[] // 파트너 취소·변경·홀드연장 요청 (T-partner-workflow-gaps) — additive
  holdExpiresAt     DateTime? // HOLD 상태에서만 사용 (24~48h)
  // 금액 — HOLD 시점 스냅샷. saleCurrency에 해당하는 통화 컬럼만 채운다 (ADR-0003)
  saleCurrency      Currency       @default(KRW)
  totalSaleKrw      Int? // 총 판매가 (KRW 채널)
  totalSaleVnd      BigInt? // 총 판매가 (VND 채널)
  totalSaleUsd      Int? // Phase 2 USD: 총 판매가 (USD 채널, 정수 달러). additive raw SQL ALTER로 라이브 반영
  fxVndPerKrw       Decimal?       @db.Decimal(14, 4) // Proposal에서 복사한 환율 스냅샷
  fxVndPerUsd       Decimal?       @db.Decimal(14, 4) // Phase 2 USD: Proposal에서 복사한 USD→VND 환율 스냅샷. additive raw SQL ALTER로 라이브 반영
  supplierCostVnd   BigInt // 총 공급자 원가
  // 보증금
  depositAmount     Int?
  depositCurrency   Currency?
  depositStatus     DepositStatus  @default(NONE)
  depositDeductVnd  BigInt? // 파손 차감액
  breakfastIncluded Boolean        @default(false)
  note              String?
  cancelReason      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  proposalItem   ProposalItem?
  checkInRecord  CheckInRecord?
  checkOutRecord CheckOutRecord?
  payments       Payment[]
  serviceOrders  ServiceOrder[]
  settlementItem SettlementItem?
  cleaningTasks  CleaningTask[]
  receivable     PartnerReceivable? // B2B 객실료 채권 (ADR-0022)

  @@index([villaId, checkIn, checkOut])
  @@index([status, holdExpiresAt])
  // perf(2026-06-27): 자주 쓰는 필터/정렬 보강. 라이브 Neon엔 additive CREATE INDEX IF NOT EXISTS로 반영.
  @@index([partnerId, createdAt]) // 파트너 포털 예약·미수 목록(where partnerId, orderBy createdAt)
  @@index([status, checkIn]) // 대시보드 오늘 체크인 프리셋, 가용성 날짜범위
  @@index([status, checkOut]) // 매출/통계 checkOut 범위 + 매출인식 상태 게이트
  @@index([parentBookingId]) // ADR-0030 T-E: 원 예약의 연장 자식 조회
}

// ===================== 체크인·아웃 검수 =====================

enum DepositStatus {
  NONE
  HELD // 수취
  REFUNDED // 전액 환불
  PARTIAL_DEDUCTED // 일부 차감
}

model CheckInRecord {
  id                String    @id @default(cuid())
  bookingId         String    @unique
  booking           Booking   @relation(fields: [bookingId], references: [id])
  passportPhotoUrls String[] // 여권 사진 (임시거주신고용 → 공급자 Zalo 전달)
  paperDocUrls      String[] @default([]) // #1 체크인 종이서류 사진(현장 서명 동의서 등, 비공개 증빙 /api/passports/doc-*)
  passportOcrJson   Json? // Gemini OCR 결과
  tamTruSentAt      DateTime? // 공급자에게 여권 전달 완료 시각
  agreementSignedAt DateTime? // 안전수칙·기물파손 동의서 서명
  signatureUrl      String?
  agreementVersion  String? // 서명 시점 동의서 판본(lib/agreement.ts AGREEMENT_VERSION) — 어느 판본에 서명했는지 추적 (ADR-0019 S3)
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
}

// 게스트 셀프 체크인 토큰 (ADR-0019 S3) — 예약별 1토큰, /g/[token] 비로그인 접근.
//   단일 예약 스코프(재고 비공개 원칙1). 만료(기본 checkOut+1일)·회수 시 차단. 재발급=새 토큰(이전 revoke).
model GuestCheckinToken {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  token       String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  firstUsedAt DateTime?
  // 게스트가 셀프로 서명한 동의서 — CheckInRecord가 아닌 토큰에 보관(관리자 completeCheckIn이
  //   기존 CheckInRecord 없음을 요구하므로 충돌 방지). 관리자 체크인 폼이 이 서명을 그대로 채택(input.signatureUrl).
  agreementSignedAt DateTime?
  signatureUrl      String? // /api/passports/sig-* (비공개 증빙 경로)
  agreementVersion  String?
  // 게스트 셀프 여권 사진(동의서 후 단계, ADR-0019 v2 #1) — 인원수만큼, 비공개 증빙(/api/passports).
  //   OCR은 관리자 체크인 단계에서. 관리자 completeCheckIn이 채택(passportPhotoUrls).
  passportPhotoUrls String[] @default([])
  createdAt   DateTime  @default(now())
}

model CheckOutRecord {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  booking         Booking   @relation(fields: [bookingId], references: [id])
  photoUrls       String[] // 공간별 상태 사진 (기준 사진과 비교)
  damageFound     Boolean   @default(false)
  damageNote      String?
  damagePhotoUrls String[]
  deductionVnd    BigInt?
  // 미니바 판매 총액(VND) — 보증금 차감(deductionVnd, 파손+미니바 혼합)과 별개로 미니바 매출만 분리 집계용.
  // 라인 합계의 비정규화 캐시(= Σ CheckoutMinibarLine.lineVnd). 미니바 통계 KPI 빠른 합산.
  minibarChargeVnd BigInt?
  // 게스트 통합 청구·정산 (ADR-0019 S4) — 미니바 소비 + 확정 부가옵션 합계. 보증금(deductionVnd)과 별개.
  //   통화별 분리(ADR-0003): VND/KRW 합산 금지. 체크아웃 시 현금/계좌이체로 수납.
  guestChargeVnd   BigInt? // 미니바 + VND 옵션 합계
  guestChargeKrw   Int? // KRW 옵션 합계
  settlementMethod GuestSettlementMethod?
  settledAt        DateTime?
  settlementNote   String?
  refundedAt      DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())

  minibarLines    CheckoutMinibarLine[]
}

// 게스트 체크아웃 정산 결제수단 (ADR-0019 S4) — PG 없음, 현장 수납.
enum GuestSettlementMethod {
  CASH // 현금
  BANK_TRANSFER // 계좌이체
  OTHER // 기타
}

// 체크아웃 미니바 판매 라인(품목별 스냅샷) — 미니바 매출·품목 인기·(원가 입력 후)마진 통계의 단일 소스.
//   소모량 기반(consumedQty) 저장. 입력 UX가 "남은 수량"으로 바뀌어도 consumedQty=stockedQty−remaining로 동일하게 저장된다.
//   판매단가(unitPriceVnd)·원가(costVnd)는 체크아웃 시점 MinibarItem 값 스냅샷(이후 가격 변경 무관). costVnd는 원가 미입력 시 null.
//   ★ ADMIN(canViewFinance) 전용 집계 — 공급자·공개 라우트 비노출(마진 비공개).
model CheckoutMinibarLine {
  id               String         @id @default(cuid())
  checkOutRecordId String
  checkOutRecord   CheckOutRecord @relation(fields: [checkOutRecordId], references: [id], onDelete: Cascade)
  minibarItemId    String? // 품목 참조 — 품목 삭제돼도 라인 보존(SetNull)
  minibarItem      MinibarItem?   @relation(fields: [minibarItemId], references: [id], onDelete: SetNull)
  nameKo           String // 품목명 스냅샷(표시·삭제 대비)
  stockedQty       Int            @default(0) // 비치 수량 스냅샷("남은 수량" 입력 UX 대비)
  consumedQty      Int // 소모 수량
  unitPriceVnd     BigInt // 판매 단가 스냅샷(VND, 동)
  costVnd          BigInt? // 매입 원가 스냅샷(VND, 동) — 원가 미입력이면 null
  lineVnd          BigInt // 판매액 = consumedQty × unitPriceVnd
  lineCostVnd      BigInt? // 원가액 = consumedQty × costVnd (costVnd null이면 null)
  createdAt        DateTime       @default(now())

  @@index([checkOutRecordId])
  @@index([minibarItemId])
}

// ===================== 청소 검수 게이트 =====================

enum CleaningType {
  CHECKOUT // 체크아웃 청소
  PERIODIC // 정기 방역 (월 1회 자동 생성)
}

enum CleaningStatus {
  PENDING // 청소 대기
  PHOTOS_SUBMITTED // 사진 업로드 완료 → 승인 대기
  APPROVED // 승인 → villa.isSellable = true
  REJECTED // 반려 → 재청소
}

model CleaningTask {
  id         String         @id @default(cuid())
  villaId    String
  villa      Villa          @relation(fields: [villaId], references: [id])
  bookingId  String?
  booking    Booking?       @relation(fields: [bookingId], references: [id])
  type       CleaningType
  status     CleaningStatus @default(PENDING)
  assigneeId String?
  assignee   User?          @relation("AssignedCleaner", fields: [assigneeId], references: [id])
  photoUrls  String[] // 공간별 청소 완료 사진
  photoSlots String[] // photoUrls와 병렬인 슬롯 id(exterior·bedroom-1…) — 선택 슬롯 스킵 시 검수 페어링 정렬용. 레거시 제출은 빈 배열
  rejectNote String?
  approvedBy String?
  approvedAt DateTime?
  dueDate    DateTime?      @db.Date
  createdAt  DateTime       @default(now())

  @@index([villaId, status])
}

// ===================== 결제·정산 =====================

enum Currency {
  KRW
  VND
  USD
}

enum PaymentMethod {
  KR_BANK_TRANSFER // 한국 계좌이체
  VN_BANK_TRANSFER
  CASH
}

model Payment {
  id            String        @id @default(cuid())
  // 마감 청구서 수납(invoiceId)은 여러 예약에 걸치므로 bookingId 없이 생성 (ADR-0027).
  // 예약 직접수납은 bookingId 필수 — "bookingId XOR invoiceId"를 앱 레벨에서 보장.
  bookingId     String?
  booking       Booking?      @relation(fields: [bookingId], references: [id])
  currency      Currency
  amount        BigInt // 통화 최소단위 (KRW 원, VND 동, USD 센트)
  method        PaymentMethod
  fxRateToVnd   Decimal?      @db.Decimal(14, 4) // 수납 시점 적용 환율
  vndEquivalent BigInt?
  receivedAt    DateTime
  note          String?
  createdAt     DateTime      @default(now())
  // B2B 파트너 입금 귀속 (ADR-0022) — 기존 고객 입금은 purpose=GUEST(default), 나머지 null
  purpose       PaymentPurpose @default(GUEST)
  partnerId     String? // 파트너 입금 시
  receivableId  String? // 예약 채권 선금/잔금 입금 시
  invoiceId     String? // 마감 청구서 수납 시

  @@index([bookingId])
  @@index([partnerId])
  @@index([receivableId])
  @@index([invoiceId])
}

// ===================== B2B 파트너 매출채권·여신 (ADR-0022) =====================
// 여행사/랜드사가 우리에게 지급하는 객실료(AR). 게스트 현장청구(보증금·미니바, ADR-0019)와 분리.

enum PartnerType {
  TRAVEL_AGENCY // 여행사
  LAND_AGENCY // 랜드사
}

enum CreditTier {
  A // 선불 (신규 기본·여신 0)
  B // 단기여신 (주/15/30일 마감·신용한도 내)
  C // 특별계약 (개별)
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED // 연체 등으로 신규예약 보류
  BLOCKED // 신규예약 전면 차단
}

enum ReceivableStatus {
  PENDING // 미입금
  PARTIAL // 일부 입금(선금만 등)
  PAID // 완납
  OVERDUE // 기한 경과 미수
  WRITTEN_OFF // 대손 처리(도망 등)
}

enum PartnerInvoiceStatus {
  DRAFT
  ISSUED // 발행(파트너에 전달)
  PARTIAL
  PAID
  OVERDUE
  VOID // 취소
}

enum PaymentPurpose {
  GUEST // 기존 고객 직접 입금(default — 하위호환)
  DEPOSIT // 파트너 예약 선금
  BALANCE // 파트너 예약 잔금
  INVOICE // 파트너 마감 청구서 수납
}

// 여행사·랜드사 정식 엔티티 (기존 BookingChannel enum + agencyName 텍스트 승격)
model Partner {
  id              String        @id @default(cuid())
  type            PartnerType
  name            String // 표시명
  nameVi          String? // 베트남어 병기 (villa-name-bilingual 정합)
  contactPhone    String?
  contactZaloUid  String? // Zalo 알림 발송 대상
  contactEmail    String?
  creditTier      CreditTier    @default(A)
  creditLimitVnd  BigInt        @default(0) // 등급 B 외상 한도(0=여신없음)
  depositRatePct  Int           @default(30) // 선금율(%) — 정책 기본 30
  paymentTermDays Int           @default(0) // 마감 후 지급기한(0=선불, 7/15/30)
  billingCycle    String? // "WEEKLY"|"BIWEEKLY"|"MONTHLY"|null(선불)
  status          PartnerStatus @default(ACTIVE)
  country         String? // ISO 3166-1 alpha-2 (KR/VN/CN…) — 청구서 PDF 언어 결정(lib/partner-country)
  contractUrl     String? // 계약서 스캔(비공개 파이프라인)
  memo            String?
  // ADR-0028 — 파트너 로그인 계정(Role=PARTNER). 엔티티≠계정 분리, 선택적 1:1 (ServiceVendor.userId 동형)
  userId          String?       @unique // 로그인 계정. null=계정 없음(운영자만 관리)
  user            User?         @relation("PartnerAccount", fields: [userId], references: [id], onDelete: SetNull)
  // ADR-0028 — 자가 회원가입 승인 게이트(ServiceVendor 미러). 자가가입=PENDING_APPROVAL, 기존·운영자생성=APPROVED
  approvalStatus  PartnerApprovalStatus @default(APPROVED)
  rejectionReason String? // 거절 사유(운영자 입력)
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings    Booking[]
  receivables PartnerReceivable[]
  invoices    PartnerInvoice[]
  proposals   Proposal[]
  changeRequests BookingChangeRequest[] // 파트너 취소·변경·홀드연장 요청 — additive

  @@index([type, status])
  @@index([approvalStatus])
}

// 파트너 자가가입 승인 상태 (ADR-0028, VendorApprovalStatus 미러)
enum PartnerApprovalStatus {
  PENDING_APPROVAL // 자가가입 후 운영자 승인 대기 — 포털 접근 차단
  APPROVED // 승인됨 — 포털 접근 가능
  REJECTED // 거절됨
}

// 예약 1건의 객실료 채권 (B2B 숙박료)
model PartnerReceivable {
  id             String           @id @default(cuid())
  partnerId      String
  partner        Partner          @relation(fields: [partnerId], references: [id])
  bookingId      String           @unique
  booking        Booking          @relation(fields: [bookingId], references: [id])
  totalVnd       BigInt // 객실료 총액(= Booking.totalSaleVnd 스냅샷)
  depositDueVnd  BigInt // = total * depositRatePct (올림)
  depositPaidVnd BigInt           @default(0)
  balancePaidVnd BigInt           @default(0)
  dueDate        DateTime         @db.Date // 잔금 기한(등급A=체크인일, B=마감+termDays)
  status         ReceivableStatus @default(PENDING)
  invoiceId      String? // 등급B 마감청구서에 묶이면 연결
  invoice        PartnerInvoice?  @relation(fields: [invoiceId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([partnerId, status])
  @@index([dueDate, status])
}

// 등급B 주/15/30일 마감 청구서 (receivable 묶음)
model PartnerInvoice {
  id           String               @id @default(cuid())
  partnerId    String
  partner      Partner              @relation(fields: [partnerId], references: [id])
  periodStart  DateTime             @db.Date
  periodEnd    DateTime             @db.Date
  dueDate      DateTime             @db.Date // periodEnd + paymentTermDays
  totalVnd     BigInt
  paidVnd      BigInt               @default(0)
  status       PartnerInvoiceStatus @default(DRAFT)
  statementUrl String? // 청구서 PDF(vi) — react-pdf, Settlement PDF 패턴 재사용
  issuedAt     DateTime?
  paidAt       DateTime?
  createdAt    DateTime             @default(now())

  receivables PartnerReceivable[]

  @@unique([partnerId, periodStart, periodEnd])
  @@index([partnerId, status])
}

enum SettlementStatus {
  DRAFT
  CONFIRMED
  COLLECTED // 고객 실수납 완료 — 공급자 지급 재원 확보 (정산 2차 P2-2)
  FX_ADJUSTED // 환차(수납 KRW vs 지급 VND 차이) 수동 반영 완료 (정산 2차 P2-2)
  PAID
}

// 공급자 월 정산 (VND 지급)
model Settlement {
  id           String           @id @default(cuid())
  supplierId   String
  supplier     User             @relation(fields: [supplierId], references: [id])
  yearMonth    String // "2026-07"
  totalVnd     BigInt
  status       SettlementStatus @default(DRAFT)
  // 생애주기 타임스탬프 (정산 2차 P2-2) — 각 단계 진입 시각
  collectedAt  DateTime? // COLLECTED 진입 (고객 수납 완료 확인)
  fxAdjustedAt DateTime? // FX_ADJUSTED 진입 (환차 반영)
  // 환차 손익 (VND, +이익/−손실) — 수납 KRW환산 vs 지급 VND 차이를 운영자 수동 입력
  fxAdjustmentVnd BigInt?
  paidAt       DateTime?
  statementUrl String? // 베트남어 정산서 PDF
  createdAt    DateTime         @default(now())

  items SettlementItem[]

  @@unique([supplierId, yearMonth])
}

model SettlementItem {
  id           String     @id @default(cuid())
  settlementId String
  settlement   Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  bookingId    String     @unique
  booking      Booking    @relation(fields: [bookingId], references: [id])
  amountVnd    BigInt
}

// ===================== 복식부기 LEDGER (정산 2차 P2-3, ADR-0018) =====================
// 모든 자금 이동을 통화별 균형 분개(차변 +, 대변 −)로 적재. 무결성은 회계항등식(통화별 합 0)으로 검증.
// ★ ADMIN(canViewFinance) 전용 — 계정잔액·매출·환차는 공급자에 절대 노출 금지.

enum LedgerAccount {
  CASH_KRW // 자산 — 한국 계좌 KRW 현금
  CASH_VND // 자산 — 베트남 계좌 VND 현금
  CASH_USD // 자산 — USD 현금(외국 게스트 USD 수납 보유분, Phase 2)
  SUPPLIER_PAYABLE // 부채 — 공급자 지급 채무(VND)
  REVENUE // 수익 — 숙박 판매 매출(수납 통화 그대로)
  COGS // 비용 — 공급자 원가(VND), SUPPLIER_PAYABLE 대차 상대
  FX_GAIN_LOSS // 손익 — 환차(VND)
}

enum LedgerEntryType {
  COLLECTION // 고객 수납 (Payment) — CASH_{C} +/ REVENUE −
  COST_ACCRUAL // 원가·채무 적립 (Settlement COLLECT) — COGS +/ SUPPLIER_PAYABLE −
  PAYOUT // 공급자 지급 (Settlement MARK_PAID) — SUPPLIER_PAYABLE +/ CASH_VND −
  FX_ADJUSTMENT // 환차 (Settlement ADJUST_FX) — CASH_VND ±/ FX_GAIN_LOSS ∓
}

model LedgerTransaction {
  id           String          @id @default(cuid())
  type         LedgerEntryType
  occurredAt   DateTime // 자금 이동 실제 시각
  // 출처 역참조 — 멱등·추적용 (정확히 하나만 채움)
  paymentId    String?         @unique // COLLECTION 1:1 멱등
  settlementId String? // COST_ACCRUAL·PAYOUT·FX (정산당 type별 1건)
  memo         String?
  createdBy    String
  createdAt    DateTime        @default(now())
  lines        LedgerLine[]

  @@index([settlementId, type])
}

model LedgerLine {
  id            String            @id @default(cuid())
  transactionId String
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account       LedgerAccount
  currency      Currency // KRW·VND
  // 차변(+)·대변(−)을 부호로. 자산·비용↑ = +, 부채·수익↑ = −. VND 동·KRW 원, float 금지.
  amount        BigInt

  @@index([transactionId])
  @@index([account, currency])
}

// ===================== 부가서비스 (Phase 2) =====================

enum ServiceType {
  BBQ // 통돼지 바베큐
  TICKET // 입장권
  GUIDE // 가이드
  CAR_RENTAL // 차량 렌트(기사 포함/불포함은 옵션)
  BREAKFAST // 조식 배달
  MOTORBIKE_RENTAL // 오토바이 렌트 (ADR-0019)
  MASSAGE // 마사지 — 풋/바디(아로마·핫스톤·건식), 출장 옵션 (ADR-0019)
  BARBER // 이발소(귀) — 시간 + 세부시술 (ADR-0019)
  FRUIT // 과일 — 바구니·도시락(카탈로그 항목으로 구분) (ADR-0023)
}

enum ServiceOrderStatus {
  REQUESTED
  CONFIRMED
  DELIVERED
  CANCELLED
}

// 부가서비스 주문 출처 — 운영자 직접(ADMIN)·게스트 셀프(GUEST)·여행사/랜드사(PARTNER). ADR-0019/0023.
enum ServiceRequestedVia {
  ADMIN
  GUEST
  PARTNER // 여행사/랜드사 요청 (/p/[token]) (ADR-0023)
}

// 발주 게이트 — 원천 공급자 가부. 공급자 수락 후에야 운영자가 고객에 확정(2단계). ADR-0023 §4.3.
enum ServiceVendorStatus {
  PENDING_VENDOR // 발주 발송, 공급자 응답 대기
  VENDOR_ACCEPTED // 공급자 수락 → 운영자 고객확정 가능
  VENDOR_REJECTED // 공급자 거절 → 운영자 대체 지정 또는 취소
}

// 원천 공급자 가입 승인 상태 (ADR-0023 S5) — 자가 회원가입 + 운영자 승인.
//   기존 행·운영자 직접생성 = APPROVED(default). 자가가입 = PENDING_APPROVAL → 운영자 승인해야 발주 수신·대시보드 활성.
enum VendorApprovalStatus {
  PENDING_APPROVAL // 자가가입 후 운영자 승인 대기
  APPROVED // 승인됨 — 카탈로그 배정·발주 수신 가능
  REJECTED // 거절됨
}

// 원천 공급자(부가서비스 외부 거래처) — 빌라 SUPPLIER와 무관한 별도 엔티티. ADR-0023 §4.1.
//   우리가 중계: 요청 → Zalo 발주 → 공급자 /vendor에서 가부 → 우리 확정·정산.
//   ★ 공급자는 자기 발주의 costVnd(=우리 지급액)만. 우리 판매가·마진·타 공급자 발주 절대 비노출.
model ServiceVendor {
  id         String   @id @default(cuid())
  userId     String?  @unique // 로그인 계정(Role=VENDOR). 엔티티≠계정 분리, 선택적 1:1
  user       User?    @relation("VendorAccount", fields: [userId], references: [id], onDelete: SetNull)
  name       String // 거래처명(예: "푸꾸옥 과일가게 A")
  nameKo     String? // 운영자 표시용(한국어), 선택
  phone      String?
  zaloUserId String? // ★ Zalo 발주 발송 대상(없으면 자동 발주 불가 — 운영자 경보)
  bankInfo   Json? // 정산 계좌(은행·계좌·예금주) — ★운영자(canViewFinance) 전용
  note       String?
  active     Boolean  @default(true)
  // ADR-0023 S5 — 자가 회원가입 승인 게이트
  approvalStatus  VendorApprovalStatus @default(APPROVED) // 자가가입=PENDING_APPROVAL, 기존·운영자생성=APPROVED
  rejectionReason String? // 거절 사유(운영자 입력)
  approvedAt      DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  catalogItems ServiceCatalogItem[]
  orders       ServiceOrder[]

  @@index([active])
  @@index([approvalStatus])
}

// 부가서비스 판매 카탈로그(주문형) — 회사 공통 1세트(미니바와 동형, villaId 없음). ADR-0019 §4.2.
//   게스트가 /g/[token]에서 고르는 "메뉴". active만 노출. 판매가(priceKrw/priceVnd)만 게스트 노출,
//   ★ costVnd(매입원가)는 운영자(canViewFinance) 전용 — 게스트·공급자·공개 라우트 절대 비노출(원칙2).
//   options = { variants:[1택·가격대체], addons:[다중·가산], modifiers:[토글·가산] } (시간티어·세부시술·출장).
model ServiceCatalogItem {
  id          String      @id @default(cuid())
  type        ServiceType
  nameKo      String // 관리자 입력(한국어만). en/vi/zh/ru는 저장 시 Gemini 자동번역 → nameI18n (ADR-0019 v2)
  nameVi      String? // (레거시) — nameI18n.vi로 대체, 하위호환 유지
  nameEn      String? // (레거시) — nameI18n.en로 대체
  nameI18n    Json? // 자동번역 {en,vi,zh,ru} — 게스트 화면 언어전환용
  descKo      String? // 관리자 입력(한국어만). 저장 시 자동번역 → descI18n
  descVi      String? // (레거시)
  descI18n    Json? // 자동번역 {en,vi,zh,ru}
  unitLabelKo String? // "1마리" "1인" "1일" 등 단위 표기
  priceKrw    Int? // (미사용) 게스트 KRW는 priceVnd×환율 올림으로 표시-시점 산출(저장 안 함)
  priceVnd    BigInt? // 판매가 VND — 관리자 입력 기준 통화
  costVnd     BigInt? // 참고 매입원가 VND — ★게스트·공급자 비노출
  photoUrl    String? // 이미지 업로드 결과 URL(/api/uploads)
  options     Json? // {variants:[{key,labelKo,labelI18n,priceVnd},...], addons, modifiers} — 라벨도 자동번역
  // ADR-0023 — 원천 공급자 + 요청 주체 자격
  vendorId    String? // 원천 공급자(발주 대상). 활성 항목은 UI 필수, 미지정=직접 제공
  vendor      ServiceVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  // 이행 방식(마사지·이발 등 APPOINTMENT) — null=미정(운영자 확인), true=픽업 제공(차량 모심), false=고객 직접 방문
  pickupAvailable Boolean? // 게스트 안내·픽업 기획 (2026-06-27, additive)
  pickupNote      String? // 픽업/매장 안내(주소·조건) — 게스트에 그대로 표기(번역 안 함)
  audiences   Json        @default("[\"ADMIN\"]") // 요청 가능 채널 ["ADMIN"|"PARTNER"|"GUEST"] — 채널별 카탈로그 서버 필터
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([active, sortOrder])
}

model ServiceOrder {
  id          String             @id @default(cuid())
  bookingId   String
  booking     Booking            @relation(fields: [bookingId], references: [id])
  type        ServiceType
  status      ServiceOrderStatus @default(REQUESTED)
  serviceDate DateTime?          @db.Date // 희망 일자(투숙기간 내)
  serviceTime String? // 희망 시각 자유입력 "HH:MM" (ADR-0019 v2 #3)
  costVnd     BigInt // 매입 원가 — 게스트 요청 단계는 0(placeholder), 운영자 확정 시 실원가
  priceKrw    Int // 판매가 KRW (주문 시점 환율 스냅샷)
  vendorName  String?
  note        String?
  // ADR-0019 — 카탈로그 연결·게스트 요청 확장
  catalogItemId   String? // 어느 카탈로그 메뉴에서 왔는지
  quantity        Int                 @default(1)
  selectedOptions Json? // 선택 variant·addon·modifier 스냅샷(가격 포함)
  requestedVia    ServiceRequestedVia @default(ADMIN)
  guestNote       String?
  priceVnd        BigInt? // 판매가 VND (스냅샷, 현지·여행사 채널)
  // ADR-0023 — 원천 공급자 발주 게이트 + 건별 정산 (로직은 S2)
  vendorId           String? // 이 주문의 원천 공급자(카탈로그 vendorId 스냅샷, 운영자 대체 가능)
  vendor             ServiceVendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorStatus       ServiceVendorStatus? // 발주 게이트 상태. 공급자 없는 직접 제공은 null
  poSentAt           DateTime? // Zalo 발주 발송 시각
  vendorRespondedAt  DateTime? // 공급자 가부 응답 시각
  vendorRejectReason String? // 거절 사유(공급자 입력)
  vendorCompletedAt  DateTime? // 공급자 서비스 이행 완료 보고 시각(null=미보고) — VENDOR_ACCEPTED에서 자가 보고(멱등)
  vendorSettledAt    DateTime? // 발주 정산 완료 시각(null=미정산). 정산액=costVnd(라인 총액 — ×quantity 금지, revenue-ledger 참조)
  vendorSettleMethod GuestSettlementMethod? // CASH | BANK_TRANSFER | OTHER (재사용)
  vendorSettleNote   String?
  // 일정 협의 — 공급자가 수락하되 대안 시간을 제안(확장 필드 패턴, 새 enum값 회피).
  //   제안 시 vendorStatus=VENDOR_ACCEPTED 유지 + 아래 필드 기록. 운영자가 적용/무시할 때까지 고객확정 차단(canConfirmCustomer).
  proposedServiceDate       DateTime? @db.Date // 공급자 제안 일자(null=제안 없음)
  proposedServiceTime       String? // 공급자 제안 시각 "HH:MM"(null=제안 없음)
  vendorProposalNote        String? // 제안 사유/비고(공급자 입력)
  vendorProposalRespondedAt DateTime? // 운영자가 제안에 응답(적용/무시)한 시각 — null이면 미해결
  createdAt   DateTime           @default(now())

  @@index([vendorId, vendorStatus])
}

// 인앱 알림 (벨 + 읽음상태) — VENDOR 포털용(ADR-0023 후속). Notification(Zalo 발송 큐)과 별도:
//   Zalo는 외부 발송 일방향, 이건 앱 내 목록·미읽음 뱃지·읽음처리가 목적. type은 DB enum 아닌 String(자유 확장).
//   비즈니스 로직은 enqueueInAppNotification(userId,...)로 적재 — 발주/취소/정산/일정제안 등.
model InAppNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "VENDOR_PO" | "VENDOR_PO_CANCELLED" | "VENDOR_SETTLED" | "VENDOR_PROPOSAL_APPLIED" 등(자유)
  title     String // 표시 제목(수신자 언어로 적재 시점에 확정)
  body      String? // 본문(품목·수량·빌라 등)
  href      String? // 클릭 시 이동 경로(예: "/vendor")
  readAt    DateTime? // null=미읽음
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// 파트너(여행사·랜드사) 예약 취소·변경·홀드연장 "요청" — 운영자 승인형 (T-partner-workflow-gaps)
//   파트너는 예약을 직접 취소·변경할 수 없다(사업원칙 — 운영자 게이트 유지). 이 테이블은 요청 큐.
//   kind/status는 String(새 enum 금지 — 라이브 additive 원칙): kind=CANCEL|MODIFY|HOLD_EXTEND,
//   status=PENDING|APPROVED|REJECTED. 라이브 반영은 additive raw SQL(prisma db execute).
model BookingChangeRequest {
  id             String    @id @default(cuid())
  bookingId      String
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  partnerId      String
  partner        Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  kind           String // "CANCEL" | "MODIFY" | "HOLD_EXTEND"
  note           String? // 파트너 요청 상세(자유 텍스트 — 희망 날짜·인원·사유 등)
  status         String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  resolvedById   String? // 처리한 운영자(User). null=미처리
  resolvedBy     User?     @relation("ChangeRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNote String? // 운영자 처리 메모(거절 사유 등 — 파트너에게 노출)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([bookingId])
  @@index([partnerId, createdAt])
}

// ===================== 감사 로그·운영 설정 =====================

// 모든 데이터 변경 추적 — 보증금 차감·정산·요율 변경 분쟁 증빙 (글로벌 audit-log-system 템플릿)
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // "CREATE" | "UPDATE" | "DELETE"
  entity    String // "Villa", "Booking", "VillaRate", "Settlement" 등
  entityId  String
  changes   Json? // { field: { old: value, new: value } }
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// 보안 이벤트 감사 채널 (보안 P0-1) — 로그인 실패·권한 거부·토큰 무효·rate-limit·SSRF/CSRF 차단 등.
// AuditLog(정상 변경·영구보존)와 분리: 고빈도 append + 단기 보존(보존 cron 후속) + type/ip/createdAt 인덱스.
// meta에는 비민감 컨텍스트만 — 비밀번호·해시·credential·마진·판매가 절대 미기록(lib/security-event.ts에서 레다크션).
model SecurityEvent {
  id          String   @id @default(cuid())
  type        String // LOGIN_FAIL | AUTHZ_DENY | TOKEN_INVALID | RATE_LIMIT | PWRESET_FAIL | CRED_DECRYPT_FAIL | SSRF_BLOCK | CSRF_BLOCK | LOGIN_OK
  actorUserId String? // 로그인/세션 사용자 id (없을 수 있음)
  actorPhone  String? // 로그인 시도 전화번호 (식별 최소 — 추적용)
  ip          String?
  path        String?
  meta        Json? // 비민감 컨텍스트만 (사유·역할·요구권한 등)
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([actorUserId])
  @@index([createdAt])
}

// 운영 설정 (예: HOLD_HOURS_DEFAULT=48) — ADR-0002
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===================== 알림 로그 =====================

enum NotificationType {
  BOOKING_HOLD
  BOOKING_CONFIRMED
  HOLD_EXPIRED
  BOOKING_CANCELLED
  CLEANING_REQUEST
  CLEANING_APPROVED
  CLEANING_REJECTED
  TAMTRU_PASSPORT // 여권 전달 (임시거주신고)
  SETTLEMENT_READY
  VILLA_REJECTED // 빌라 반려 — 공급자에게 반려 사유 전달 (T1.2b)
  RATE_CHANGED_DURING_PROPOSAL // 제안 진행 중 원가/요율 변경 알림 — 운영자 통지 (ADR-0008)
  ROSTER_REMINDER // 체크인 D-3 투숙객 명단 미입력 — 운영자(테오) 리마인드 (T-roster-reminder-cron)
  SUPPLIER_DIRECT_BOOKING // 공급자 직접예약 생성 — 운영자에게 선점 기회 통지 (F10, ADR-0021)
  VENDOR_PO // 원천 공급자에게 부가서비스 발주 — 수신자=공급자 User(vi) (ADR-0023 S2)
  VENDOR_PO_RESPONSE // 공급자 가부 응답 → 운영자 통지(ko) (ADR-0023 S2)
  BOOKING_MODIFIED // 예약 변경(날짜·빌라·인원 등) → 공급자 통지 (F-booking-modify, 판매가·마진 비포함)
  VENDOR_PO_CANCELLED // 발주된 주문 취소 → 원천 공급자에게 취소 통보(vi). 운영자 취소 경로(PATCH service-orders)에서 발송
  SECURITY_ALERT // 보안 이상탐지 경보 → 운영자(테오) 통지(ko). P3-S3, 비번·PII 평문 미포함. additive: 라이브 ALTER TYPE ADD VALUE
  VILLA_PENDING_REVIEW // 빌라 신규 등록·반려 후 재제출 → 운영자 통지(ko). payload.resubmitted 텍스트 분기. additive: 라이브 ALTER TYPE ADD VALUE
  VILLA_CONTENT_UPDATED // 승인(ACTIVE) 후 공급자 사진/비품/규칙 수정 → 운영자 통지(ko). PENDING dedup 스팸 방지. additive: 라이브 ALTER TYPE ADD VALUE
  VENDOR_PROPOSAL_RESULT // 일정 제안 결과(적용/무시) → 원천 공급자 통지(payload.locale ko/vi). additive: 라이브 ALTER TYPE ADD VALUE
  GUEST_PAYMENT_NOTICE // 게스트 "입금했습니다" 통보 → 운영자 통지(ko). 48h 홀드만료 전 입금확인 유도 (A1). additive: 라이브 ALTER TYPE ADD VALUE
  SERVICE_ORDER_REQUESTED // 게스트/파트너 부가서비스 요청 → 운영자 통지(ko). 금액 미포함 (A1). additive: 라이브 ALTER TYPE ADD VALUE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  type      NotificationType
  channel   String             @default("ZALO") // ZALO | WEBPUSH
  payload   Json
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  error     String?
  createdAt DateTime           @default(now())

  @@index([userId, status])
}

// ===================== Zalo 양방향 채팅 (v1.2 — ADR-0003) =====================

enum ZaloMessageDirection {
  INBOUND // 공급자 → OA (webhook 수신)
  OUTBOUND // OA → 공급자
}

enum ZaloMessageSource {
  USER // 공급자 발신 (INBOUND)
  CHAT // 관리자 채팅 수동 발신 (b14)
  SYSTEM // F5 알림 발송 미러 기록 — Notification은 상태 추적용으로 별도 유지
}

enum ZaloMessageStatus {
  RECEIVED
  SENT
  FAILED
}

// 채팅 상대 타입 (ADR-0009 D1, 개정 2026-06-16 분류 5종) — 공유 누수 분기 기준.
//  누수 그룹(D2):
//   · 원가측 = {SUPPLIER}                                 → 빌라=원가만, 정산 공유 허용, 제안 금지
//   · 판매가측 = {CUSTOMER, TRAVEL_AGENCY, LAND_AGENCY}    → 빌라=판매가만(원가·마진 금지), 제안 허용, 정산 금지
//   · UNKNOWN                                             → 사진만(공유 잠금)
//  마진(marginType/marginValue)은 전 그룹 영구 금지(불변).
//  통화 매핑(D2 통화): CUSTOMER=KRW(직접 소비자), TRAVEL_AGENCY·LAND_AGENCY=VND (ADR-0003 채널 통화 정합).
//  → 빌라 공유 본문 saleCurrency를 분류별로 결정(BE: currencyForType()). 보류됐던 "고객 통화 분기" 해소.
enum ZaloCounterpartyType {
  SUPPLIER // 공급자(중계인·부동산·분양자) — 원가만 (원가측)
  CUSTOMER // 직접 고객(여행객) — 판매가 KRW만 (판매가측)
  TRAVEL_AGENCY // 여행사 — 판매가 VND만 (판매가측, ADR-0003 여행사=VND)
  LAND_AGENCY // 랜드사 — 판매가 VND만 (판매가측, ADR-0003 랜드사=VND)
  UNKNOWN // 미분류 — 공유 기능 잠금(기본값, 사진만). 분류 배너 노출 대상
  IGNORED // 개인/기타(업무 상대 아님) — 종착 분류, 배너 미노출, 공유 잠금(사진만). 개인 Zalo·스팸 등
}

// 대화별 번역 모드 (ADR-0009 D7) — ADMIN 기준 언어는 항상 ko. 모드는 "상대 언어" 1축만 저장.
//  OFF: 수신 자동번역·발신 미리보기 둘 다 끔(Gemini 호출 0). VI: ko↔vi. EN: ko↔en.
enum ZaloTranslateMode {
  OFF // 번역 끔 (한국어끼리)
  VI // 상대 베트남어 — 수신 vi→ko, 발신 ko→vi
  EN // 상대 영어 — 수신 en→ko, 발신 ko→en
}

// 대화 스레드 종류 (ADR-0010 그룹 D1, S4) — 1:1 개인 대화 vs 그룹(단톡방).
//  USER: 상대 1명(zaloUserId=상대 Zalo id). 기존 모든 대화 = USER(백필 기본값).
//  GROUP: 단톡방(zaloUserId=그룹 id). 여러 발신자가 섞임 → ZaloMessage.senderUid로 발신자 식별,
//         ZaloConversation.groupMembers 스냅샷으로 발신자명·아바타 매핑(R14 미해석 시 senderUid 폴백).
enum ZaloThreadType {
  USER // 1:1 개인 대화 (기본)
  GROUP // 그룹(단톡방)
}

// 대화 스레드 — 관리자×상대(공급자) 단위 (ADR-0007 D3).
// ownerAdminId: 이 대화를 받은/소유한 ADMIN (개인 스코프 기준). 시스템봇 미러는 시스템봇 소유자(테오) 소유.
// 같은 공급자가 관리자 A·B와 각각 대화하면 행 2개(ownerAdminId만 다름) — 카카오톡 모델.
// zaloUserId @unique 제거 → @@unique([ownerAdminId, zaloUserId]) 복합키 (관리자별 격리).
model ZaloConversation {
  id            String    @id @default(cuid())
  ownerAdminId  String // 이 대화를 소유한 ADMIN (수신/발신 주체 계정의 소유자) — ADR-0007
  ownerAdmin    User      @relation("AdminConversations", fields: [ownerAdminId], references: [id], onDelete: Cascade)
  zaloUserId    String // 대화 상대(공급자)의 Zalo id — @unique 제거 (복합키로 이동)
  userId        String? // 매칭된 공급자 User (전역 User.zaloUserId 기준) — @unique 제거 (1:N)
  user          User?     @relation("SupplierConversations", fields: [userId], references: [id], onDelete: SetNull)
  displayName   String? // Zalo 프로필명 (원본 — nickname과 구분, ADR-0009 D9.1)
  lastMessageAt DateTime?
  // 인박스 미리보기 비정규화(perf, 2026-06-24) — 대화별 messages take1 서브쿼리 제거(클릭마다 재실행되던 인박스 병목).
  // 마지막 메시지 본문·타입. 메시지 쓰기 경로가 lastMessageAt와 함께 갱신. 표시 전용(누수 무관: 본문/타입만).
  lastMessageText String?
  lastMessageType String?
  lastInboundAt DateTime? // ADR-0006 D5.5 — 개인계정은 48h 제약 없음(참고 보존)
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())

  // ADR-0009 (additive) — D1 상대 타입, D7 번역모드, D8 아바타, D9 별명.
  counterpartyType ZaloCounterpartyType @default(UNKNOWN) // D1 — 기존 행은 SUPPLIER 백필
  translateMode    ZaloTranslateMode    @default(VI) // D7 개정(2026-06-18) — 베트남 상대 위주라 기본 VI(수신 vi→ko 자동). 한국 직접 고객만 개별 OFF
  avatarUrl        String? // D8 — Zalo 아바타 URL 캐시 (없으면 이니셜 폴백)
  avatarFetchedAt  DateTime? // D8 — 마지막 아바타 조회 시각 (주기 갱신 판단)
  nickname         String? // D9 — ADMIN 지정 별명 (표시 최우선, displayName 원본 보존)

  // ADR-0010 그룹 D (S4, additive) — 그룹 채팅. 기존 행은 threadType USER 백필.
  threadType   ZaloThreadType @default(USER) // D1 — USER(1:1) | GROUP(단톡방). zaloUserId 슬롯에 그룹은 그룹 id 저장
  groupMembers Json? // D2 — 그룹 멤버 스냅샷 [{zaloId,name,avatarUrl}]. 발신자명·아바타 매핑 원천. 1:1은 null

  messages ZaloMessage[]

  @@unique([ownerAdminId, zaloUserId]) // 관리자×상대 단위 (기존 zaloUserId @unique 대체)
  @@index([ownerAdminId, lastMessageAt])
}

model ZaloMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   ZaloConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      ZaloMessageDirection
  source         ZaloMessageSource
  msgType        String               @default("text") // text | image | sticker | file
  text           String?
  attachmentUrls String[]
  translatedText String? // Gemini 번역 캐시 — 수신 vi→ko 자동, 발신 ko→vi 미리보기 후 전송
  // 사진 캡션 번역(ko) — 사진 메시지의 translatedText는 이미지 OCR 번역 전용이라 분리.
  // 같은 사진에 캡션 번역과 이미지 속 글자 OCR이 둘 다 필요한 사례 대응(additive, 기존 행 null).
  captionTranslated String?
  zaloMsgId      String?              @unique // Zalo msg_id (webhook 멱등성)
  status         ZaloMessageStatus
  error          String?
  sentBy         String? // OUTBOUND CHAT: 발신 ADMIN userId
  senderUid      String? // ADR-0010 그룹 D3 (S4) — 그룹 메시지의 발신자 Zalo id(누가 보냈는지). 1:1은 null(상대 고정)
  createdAt      DateTime             @default(now())

  // ── 답글(인용)·리액션 (ADR-0009 개정3, additive) ──
  // zca-js는 리액션(addReaction)·답글(sendMessage quote)에 Zalo 서버 msgId와 함께 cliMsgId를 요구한다.
  // 기존 행은 cliMsgId=null(과거 메시지엔 리액션·답글 불가 — 신규 발송·수신분부터. 백필 불필요).
  cliMsgId String? // zca-js cliMsgId — 리액션(addReaction: msgId+cliMsgId 둘 다 필요)·답글 대상 식별. 발송·수신 시 저장

  // 답글 인용 — self-relation 대신 스냅샷(단순·안전). 원본 메시지가 삭제돼도 인용 표시 보존.
  quotedMsgId  String? // 인용된 원본 메시지의 zaloMsgId (참조용, FK 아님)
  quotedText   String? // 인용 본문 스냅샷 (인용 블록 표시용)
  quotedSender String? // 인용 발신자 표시명 스냅샷

  // 답글 인용 점프 앵커 변환용 (additive) — zca-js quote.globalMsgId는 버블 앵커 zaloMsgId(=msgId)와
  // 다른 ID 체계라, 수신 답글의 quotedMsgId(=globalMsgId)를 zaloMsgId로 변환하려면 메시지별 globalMsgId
  // 보관이 필요하다(Nike resolveQuoteMsgIds 패턴). 기존 행은 null — 신규 수신·발신분부터(백필 불필요).
  globalMsgId  String? // zca-js globalMsgId — 답글 인용 앵커(globalMsgId→zaloMsgId) 변환 키

  // 리액션 집계 — 수신 reaction 이벤트로 갱신. 예: { "HEART": 2, "LIKE": 1 }.
  // Phase 1은 누가 달았는지까지는 불필요 — 아이콘별 카운트 집계만. 아이콘은 문자열(zca-js Reactions enum 키, 예 "HEART").
  reactions Json? // 메시지에 달린 리액션 집계

  @@index([conversationId, createdAt])
  // 답글 인용 앵커 DB 폴백(배치 밖 원본) 조회용 — where conversationId + globalMsgId in [...].
  @@index([conversationId, globalMsgId])
}

// ===================== Zalo 봇 계정 (ADR-0006 — zca-js 개인 계정 QR 로그인) =====================

// 봇 계정 (ADR-0007 멀티). kind로 시스템봇/관리자 개인 계정 구분.
//  - SYSTEM_BOT: F5 알림 발송 전용 (테오 소유, 풀 키 "__system__"). Phase 1은 테오 개인 채팅도 겸용(통합 모드, D1).
//  - ADMIN_PERSONAL: 각 관리자의 개인 채팅 계정 (풀 키 = userId).
// 주의: ZaloAccount.zaloUserId(봇 자신의 Zalo id) ≠ User.zaloUserId / ZaloConversation.zaloUserId(대화 상대=공급자).
//       컬럼명이 겹치지만 의미가 다르다 (ADR-0006 D3).
// 보안(D6): credentials는 AES-256-GCM 암호문. 응답·로그·AuditLog·SSE 절대 노출 금지. select 명시 로드만.
enum ZaloAccountKind {
  SYSTEM_BOT // F5 알림 발송 전용 (테오 소유, 풀 키 "__system__")
  ADMIN_PERSONAL // 관리자 개인 채팅 계정 (풀 키 = userId)
}

model ZaloAccount {
  id            String          @id @default(cuid())
  zaloUserId    String          @unique // 봇 계정의 Zalo own id (login 성공 후 getOwnId)
  kind          ZaloAccountKind @default(SYSTEM_BOT) // ADR-0007 — 기존 행은 SYSTEM_BOT으로 백필
  userId        String // 봇을 소유한 ADMIN User.id (nullable→필수) — 개인계정=본인, 시스템봇=테오
  user          User            @relation("AdminZaloAccounts", fields: [userId], references: [id], onDelete: Cascade)
  credentials   String? // AES-256-GCM 암호문 (imei+cookie+userAgent) — 절대 평문/응답/로그 금지
  displayName   String?
  isActive      Boolean         @default(true)
  lastConnected DateTime?
  createdAt     DateTime        @default(now())

  @@unique([userId, kind]) // 관리자 1명당 kind별 1계정 (개인 1 + (테오만)시스템 1)
  @@index([isActive])
  @@index([kind, isActive])
}
