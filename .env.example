# Neon PostgreSQL (연결 풀링 URL 사용 — ?pgbouncer=true&connect_timeout=15)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/villa-pms?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-app.railway.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Zalo zca-js (개인 계정 QR 로그인 — ADR-0005/0006, OA 폐기)
# credential AES-256-GCM 암호화 키. 운영 중 변경 금지(기존 저장 credential 복호화 불가 → 재QR 필요)
ZALO_CREDS_KEY="generate-with: openssl rand -base64 32"

# Gemini (번역·OCR)
GEMINI_API_KEY=""
GEMINI_MODEL=""             # 선택 — 기본 gemini-2.5-flash (모델 퇴역 시 핀 교체용)

# 이미지 저장소 — 인터림 디스크 (T0.4 R2 전환 전). 미설정 시 ./public/uploads
UPLOAD_DIR=""

# 이미지 저장소 (Cloudflare R2)
STORAGE_ACCOUNT_ID=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="villa-pms-uploads"
STORAGE_PUBLIC_URL=""

# Cron 보안
CRON_SECRET="generate-with: openssl rand -base64 32"

# Nike↔villa Zalo 통합 (ADR-0010)
# S1 발송·S2 읽기 공통 ext 시크릿(서버-서버, x-zalo-ext-secret 헤더). Nike와 동일 값.
ZALO_EXT_SHARED_SECRET="generate-with: openssl rand -base64 32"
# 테오(SYSTEM_BOT 소유자) ownerAdminId 폴백(DB 동적 해석 실패 시). 보통 미설정 — DB 우선.
ZALO_SYSTEM_OWNER_ID=""
# S2 수신 webhook push 대상 — Nike webhook 수신 라우트 URL. 미설정 시 push no-op.
NIKE_WEBHOOK_URL=""
# S2 webhook HMAC 서명 키(villa 서명·Nike 검증, 양 레포 동일 값). ext 시크릿과 다른 값.
ZALO_WEBHOOK_HMAC_SECRET="generate-with: openssl rand -base64 32"
# 첨부 절대 URL 보정용 base(상대경로 첨부를 villa 절대 URL로). 미설정 시 STORAGE_PUBLIC_URL/NEXTAUTH_URL 폴백.
VILLA_PUBLIC_BASE_URL=""
